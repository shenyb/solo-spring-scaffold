#!/usr/bin/env python3
"""
solo-spring-scaffold — Spring Boot 3.x 项目脚手架生成器

用法:
    python solo-spring-scaffold init my-app --package com.example.myapp --jdk 21
    python solo-spring-scaffold init my-app --package com.example.myapp --jdk 21 \\
        --db-url jdbc:mysql://192.168.1.100:3306/mydb --db-user root --db-pass xxx
    python solo-spring-scaffold init my-app --package com.example.myapp --jdk 21 \\
        --plugins security,docker,test
    python solo-spring-scaffold list-plugins
"""
import argparse
import os
import re
import shutil
import sys
import stat
from pathlib import Path
from typing import Optional

# ─── 版本映射 ───
SPRING_BOOT_VERSIONS = {
    17: "3.2.5",
    21: "3.3.8",
    25: "3.4.4",
}

SCRIPT_DIR = Path(__file__).parent
TEMPLATES_DIR = SCRIPT_DIR / "templates"
GENERATOR_TPL_DIR = SCRIPT_DIR / "generator_tpl"
BIN_TPL_DIR = SCRIPT_DIR / "bin_tpl"
PLUGINS_DIR = SCRIPT_DIR / "plugins"

# 内置插件（P0 优先级）
BUILTIN_PLUGINS = {
    "security": "Spring Security + JWT 认证/鉴权",
    "docker": "Dockerfile + docker-compose.yml",
    "test": "单元/集成测试模板（JUnit 5 + Mockito）",
    "redis": "Redis + Spring Cache 配置",
    "actuator": "Spring Boot Actuator + Prometheus 指标",
}

# 需要替换的占位符文件
PLACEHOLDER_FILES = {
    "{{ProjectName}}Application.java",
}

# 需要 chmod +x 的脚本文件
EXECUTABLE_SCRIPTS = {
    "bin/start.sh",
    "bin/stop.sh",
    "bin/deploy.sh",
    "bin/gen-tables.sh",
}


class Color:
    GREEN = "\033[92m"
    YELLOW = "\033[93m"
    CYAN = "\033[96m"
    RESET = "\033[0m"
    BOLD = "\033[1m"


def ok(msg: str):
    print(f"{Color.GREEN}✓{Color.RESET} {msg}")


def info(msg: str):
    print(f"{Color.CYAN}→{Color.RESET} {msg}")


def warn(msg: str):
    print(f"{Color.YELLOW}⚠ {msg}{Color.RESET}")


def to_pascal_case(name: str) -> str:
    """将 kebab-case 或 snake_case 转 PascalCase"""
    return "".join(word.capitalize() for word in re.split(r"[-_]", name))


def to_package_dir(package: str) -> str:
    """com.example.myapp → com/example/myapp"""
    return package.replace(".", "/")


def resolve_jdk(jdk: int) -> int:
    if jdk not in SPRING_BOOT_VERSIONS:
        raise ValueError(
            f"不支持的 JDK 版本: {jdk}。支持的版本: {', '.join(map(str, SPRING_BOOT_VERSIONS.keys()))}"
        )
    return jdk


