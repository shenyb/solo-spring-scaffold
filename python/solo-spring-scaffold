    print(f"   → http://localhost:8080/swagger-ui.html\n")


def cmd_init(args):
    """处理 init 子命令"""
    project_name = args.name
    project_path = Path.cwd() / project_name

    if project_path.exists():
        print(f"{Color.YELLOW}⚠ 目录 {project_path} 已存在！{Color.RESET}")
        resp = input("是否覆盖？(y/N): ")
        if resp.lower() != "y":
            print("已取消")
            return
        shutil.rmtree(project_path)

    try:
        resolve_jdk(args.jdk)
    except ValueError as e:
        print(f"{Color.YELLOW}{e}{Color.RESET}")
        sys.exit(1)

    # 解析插件列表
    plugins = []
    if args.plugins:
        plugins = [p.strip() for p in args.plugins.split(",") if p.strip()]

        # 验证插件是否存在
        for p in plugins:
            if not (PLUGINS_DIR / p / "plugin.yaml").exists():
                warn(f"插件 '{p}' 不存在，可用插件: {', '.join(BUILTIN_PLUGINS.keys())}")
                sys.exit(1)

    generate_project(
        project_path=project_path,
        project_name=project_name,
        base_package=args.package,
        jdk_version=args.jdk,
        db_url=args.db_url,
        db_user=args.db_user,
        db_pass=args.db_pass,
        plugins=plugins,
    )


def cmd_list_plugins(args):
    """列出所有可用插件"""
    plugins = list_available_plugins()

    if not plugins:
        print("没有找到可用插件")
        return

    print(f"\n{Color.BOLD}可用插件 ({len(plugins)}):{Color.RESET}\n")
    for p in plugins:
        print(f"  {Color.GREEN}{p['name']}{Color.RESET} — {p.get('description', '无描述')}")
        print(f"    版本: {p.get('version', '?')}  分类: {p.get('category', '?')}  标签: {', '.join(p.get('tags', []))}")
        if p.get("requires"):
            print(f"    依赖: {', '.join(p['requires'])}")
        print()


def main():
    parser = argparse.ArgumentParser(
        description="solo-spring-scaffold — Spring Boot 3.x 项目脚手架生成器",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\n示例:
  # 生成骨架（H2 内存库，开箱即用）
  python solo-spring-scaffold init my-app --package com.example.myapp --jdk 21

  # 生成骨架 + MySQL 代码生成器
  python solo-spring-scaffold init my-app --package com.example.myapp --jdk 21 \\
      --db-url jdbc:mysql://192.168.1.100:3306/mydb --db-user root --db-pass xxx

  # 生成骨架 + 启用插件
  python solo-spring-scaffold init my-app --package com.example.myapp --jdk 21 \\
      --plugins security,docker,test

  # 查看可用插件
  python solo-spring-scaffold list-plugins
""",
    )

    subparsers = parser.add_subparsers(dest="command", help="子命令")
    init_parser = subparsers.add_parser("init", help="初始化新项目")
    init_parser.add_argument("name", help="项目名称（如 my-app）")
    init_parser.add_argument("--package", "-p", required=True, help="包名（如 com.example.myapp）")
    init_parser.add_argument(
        "--jdk", "-j", type=int, default=21,
        help=f"JDK 版本: {', '.join(map(str, SPRING_BOOT_VERSIONS.keys()))}（默认 21）",
    )
    init_parser.add_argument("--db-url", help="MySQL 连接地址（可选）")
    init_parser.add_argument("--db-user", help="MySQL 用户名")
    init_parser.add_argument("--db-pass", help="MySQL 密码")
    init_parser.add_argument(
        "--plugins", "-P",
        help=f"启用插件，逗号分隔（如 security,docker,test）。可用: {', '.join(BUILTIN_PLUGINS.keys())}",
    )

    list_parser = subparsers.add_parser("list-plugins", help="列出可用插件")

    args = parser.parse_args()

    if args.command == "init":
        cmd_init(args)
    elif args.command == "list-plugins":
        cmd_list_plugins(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
